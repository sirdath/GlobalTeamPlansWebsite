---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Global Team Plans — Global employee wellbeing, made simple',
  description = 'Global Team Plans helps companies access trusted global health, wellbeing, and EAP programmes — delivered as a certified TELUS Health partner agency across 180+ countries.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7REQ8N24GS" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7REQ8N24GS');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="EAP, TELUS Health partner, employee assistance programme, workplace wellbeing, enterprise mental health, GDPR EAP, clinical governance, global EAP" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFFFFF" />

    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- frontendmaxxing snippets (world map, paper grain, mesh bg) -->
    <link rel="stylesheet" href="/fxm/world-map.css" />
    <link rel="stylesheet" href="/fxm/noise-grain.css" />
    <link rel="stylesheet" href="/fxm/mesh-bg-stripe.css" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:site_name" content="Global Team Plans" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/og-image.png', Astro.site)} />

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Global Team Plans",
      "url": "https://globalteamplans.com",
      "description": "Certified TELUS Health partner agency. We sell and implement Employee Assistance Programmes to enterprises operating across borders.",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "find@gtpinsurance.gr",
        "contactType": "sales"
      },
      "areaServed": "Worldwide",
      "knowsAbout": ["Employee Assistance Programme", "Workplace Wellbeing", "TELUS Health"]
    }
    </script>

    <!-- Pre-paint: hide reveal targets to avoid flash before GSAP boots -->
    <style is:inline>
      [data-reveal], [data-reveal-stagger] > *, [data-split] {
        opacity: 0;
      }
      html.no-gsap [data-reveal],
      html.no-gsap [data-reveal-stagger] > *,
      html.no-gsap [data-split] {
        opacity: 1;
      }
      @media (prefers-reduced-motion: reduce) {
        [data-reveal], [data-reveal-stagger] > *, [data-split] {
          opacity: 1 !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />

    <!-- GSAP core + ScrollTrigger + SplitText (native scroll, no ScrollSmoother) -->
    <script src="/fxm/gsap/gsap.min.js" is:inline defer></script>
    <script src="/fxm/gsap/ScrollTrigger.min.js" is:inline defer></script>
    <script src="/fxm/gsap/SplitText.min.js" is:inline defer></script>

    <!-- World map (Partnership section) -->
    <script src="/fxm/world-map.js" is:inline defer></script>

    <script is:inline>
      (function () {
        function boot() {
        if (!window.gsap) {
          document.documentElement.classList.add('no-gsap');
          return;
        }
        var gsap = window.gsap;
        gsap.registerPlugin(ScrollTrigger, SplitText);

        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ──────────────────────────────────────────────────────────
        // [data-reveal] — single element fade/slide on enter viewport
        // ──────────────────────────────────────────────────────────
        gsap.utils.toArray('[data-reveal]').forEach(function (el) {
          var dir = el.dataset.reveal || 'up';
          var delay = parseFloat(el.dataset.revealDelay || '0');
          var fromVars = { opacity: 0, y: dir === 'up' ? 24 : dir === 'down' ? -24 : 0, x: dir === 'left' ? -24 : dir === 'right' ? 24 : 0 };
          gsap.fromTo(el, fromVars, {
            opacity: 1, x: 0, y: 0,
            duration: 0.9,
            ease: 'power3.out',
            delay: delay,
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
          });
        });

        // ──────────────────────────────────────────────────────────
        // [data-reveal-stagger] — stagger immediate children
        // ──────────────────────────────────────────────────────────
        gsap.utils.toArray('[data-reveal-stagger]').forEach(function (parent) {
          var kids = parent.querySelectorAll(':scope > *');
          gsap.fromTo(kids, { opacity: 0, y: 18 }, {
            opacity: 1, y: 0,
            duration: 0.7, ease: 'power3.out',
            stagger: 0.08,
            scrollTrigger: { trigger: parent, start: 'top 85%', once: true },
          });
        });

        // ──────────────────────────────────────────────────────────
        // [data-split] — word-by-word stagger reveal (headlines)
        // ──────────────────────────────────────────────────────────
        gsap.utils.toArray('[data-split]').forEach(function (el) {
          try {
            var split = new SplitText(el, { type: 'words', wordsClass: 'word' });
            gsap.set(el, { opacity: 1 });
            gsap.fromTo(split.words, { opacity: 0, y: 28 }, {
              opacity: 1, y: 0,
              duration: 0.85, ease: 'power3.out',
              stagger: 0.04,
              scrollTrigger: { trigger: el, start: 'top 88%', once: true },
            });
          } catch (e) {
            gsap.set(el, { opacity: 1 });
          }
        });

        // ──────────────────────────────────────────────────────────
        // [data-count-up] — number roll on enter viewport
        // ──────────────────────────────────────────────────────────
        gsap.utils.toArray('[data-count-up]').forEach(function (el) {
          var target = parseFloat(el.dataset.countUp || '0');
          var suffix = el.dataset.countSuffix || '';
          var prefix = el.dataset.countPrefix || '';
          var dec    = parseInt(el.dataset.countDecimals || '0', 10);
          var obj = { v: 0 };
          el.textContent = prefix + (0).toFixed(dec) + suffix;
          gsap.to(obj, {
            v: target,
            duration: 2,
            ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 85%', once: true },
            onUpdate: function () {
              el.textContent = prefix + obj.v.toFixed(dec) + suffix;
            },
          });
        });

        // ──────────────────────────────────────────────────────────
        // [data-tilt] — soft pointer-tracked 3D tilt on cards.
        // SKIP on touch devices: iOS Safari fires pointermove on tap
        // and leaves the card rotated until next tap. Mouse-only.
        // ──────────────────────────────────────────────────────────
        var fineHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        gsap.utils.toArray('[data-tilt]').forEach(function (card) {
          if (reduced || !fineHover) return;
          var max = parseFloat(card.dataset.tiltMax || '6');
          card.style.transformStyle = 'preserve-3d';
          card.style.transformPerspective = '1000px';
          var qX = gsap.quickTo(card, 'rotationX', { duration: 0.5, ease: 'power2.out' });
          var qY = gsap.quickTo(card, 'rotationY', { duration: 0.5, ease: 'power2.out' });
          var qS = gsap.quickTo(card, 'scale',     { duration: 0.5, ease: 'power2.out' });
          card.addEventListener('pointermove', function (e) {
            var r = card.getBoundingClientRect();
            var px = (e.clientX - r.left) / r.width  - 0.5;
            var py = (e.clientY - r.top)  / r.height - 0.5;
            qY(px * max);
            qX(-py * max);
            qS(1.02);
          });
          card.addEventListener('pointerleave', function () {
            qX(0); qY(0); qS(1);
          });
        });

        // ──────────────────────────────────────────────────────────
        // Refresh ScrollTrigger after fonts + images settle
        // ──────────────────────────────────────────────────────────
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(function () { ScrollTrigger.refresh(); });
        }
        window.addEventListener('load', function () { ScrollTrigger.refresh(); });
        }

        // Deferred GSAP scripts finish before DOMContentLoaded, so boot then.
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', boot);
        } else {
          boot();
        }
      })();
    </script>
  </body>
</html>
