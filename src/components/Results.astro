---

<section id="results" class="py-24 md:py-32 px-4 relative">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Proven <span class="text-teal">Results & Measurable Impact</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-base md:text-lg">
        Evidence-based wellbeing solutions that deliver tangible business outcomes and ROI.
      </p>
    </div>

    <!-- Impact Stats with SVG Progress Rings -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-20">
      {impactStats.map(stat => (
        <div class="glass-card p-8 rounded-2xl text-center reveal">
          <div class="relative inline-block mb-4">
            <svg class="w-32 h-32" viewBox="0 0 120 120">
              <!-- Background ring -->
              <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="8"/>
              <!-- Progress ring -->
              <circle
                class="progress-ring-circle"
                cx="60" cy="60" r="52"
                fill="none"
                stroke="var(--color-primary)"
                stroke-width="8"
                stroke-linecap="round"
                stroke-dasharray={2 * Math.PI * 52}
                stroke-dashoffset={2 * Math.PI * 52}
                data-target={stat.value}
              />
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-3xl md:text-4xl font-extrabold text-teal">{stat.value}%</span>
            </div>
          </div>
          <div class="text-lg font-semibold text-white">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
      {benefits.map(benefit => (
        <div class="flex items-start gap-4 p-6 rounded-xl reveal group hover:bg-white/[0.02] transition-colors duration-300">
          <div class="w-10 h-10 bg-teal rounded-xl flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:scale-110">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d={benefitIconPaths[benefit.icon]} clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-teal transition-colors duration-300">
              {benefit.title}
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed">{benefit.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Accreditations -->
    <div class="text-center reveal">
      <h3 class="text-2xl font-bold text-teal mb-3">Trusted by Organizations Worldwide</h3>
      <p class="text-gray-400 mb-10">
        Accredited by the Council on Accreditation with strict clinical governance standards.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {accreditations.map(acc => (
          <div class="glass-card p-6 rounded-xl text-center reveal">
            <div class="w-10 h-10 bg-teal/10 rounded-xl flex items-center justify-center mb-4 mx-auto">
              <svg class="w-5 h-5 text-teal" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d={accreditationIcons[acc.icon]} clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-bold text-white mb-2">{acc.title}</h4>
            <p class="text-gray-400 text-sm">{acc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Animate progress rings on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const circles = entry.target.querySelectorAll('.progress-ring-circle');
        circles.forEach(circle => {
          const target = Number((circle as SVGCircleElement).dataset.target);
          const circumference = 2 * Math.PI * 52;
          const offset = circumference - (target / 100) * circumference;
          (circle as SVGCircleElement).style.strokeDashoffset = String(offset);
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.progress-ring-circle').forEach(circle => {
    const parent = circle.closest('section');
    if (parent) observer.observe(parent);
  });
</script>
