---
interface Props {
  title: string;
  description: string;
  features: string[];
  type: 'crisis' | 'counselling' | 'digital' | 'worklife' | 'community' | 'analytics';
}

const { title, description, features, type } = Astro.props;

const getIcon = (type: string) => {
  switch(type) {
    case 'crisis': return '<path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01" />';
    case 'counselling': return '<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />';
    case 'digital': return '<rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round" /><path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8M12 17v4" />';
    case 'worklife': return '<path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />';
    case 'community': return '<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />';
    case 'analytics': return '<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M18 17V9m-5 8v-4m-5 8V5" />';
    default: return '<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />';
  }
};
---

<div class="glass-card p-6 md:p-8 rounded-3xl border-white/[0.03] flex flex-col items-start hover:border-teal/20 group transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(45,212,191,0.1)]">
  <div class="w-16 h-16 mb-6 relative flex items-center justify-center bg-teal/10 rounded-2xl group-hover:bg-teal/20 transition-colors duration-500">
    <!-- Subtle glow behind the SVG icon -->
    <div class="absolute inset-0 bg-teal/20 blur-xl rounded-full scale-150 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="relative z-10">
      <svg viewBox="0 0 24 24" fill="none" class="w-8 h-8 text-teal group-hover:text-emerald-400 transition-colors duration-500" stroke="currentColor" stroke-width="1.5" set:html={getIcon(type)}></svg>
    </div>
  </div>
  
  <h3 class="text-xl font-bold text-white mb-3 group-hover:text-teal transition-colors duration-300">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed mb-6">{description}</p>
  
  <ul class="space-y-2 mt-auto">
    {features.map(feature => (
      <li class="flex items-center text-xs text-slate-500">
        <span class="text-teal/60 mr-2">✓</span>
        {feature}
      </li>
    ))}
  </ul>
</div>
