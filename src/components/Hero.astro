---
import { heroStats } from '../data/stats';
import GlobeScene from './3d/GlobeScene';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- 3D Globe Background -->
  <div class="absolute inset-0 z-0 opacity-40 md:opacity-100 pointer-events-none" id="heroBackground">
    <GlobeScene client:only="react" className="h-full w-full pointer-events-none" />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 text-center" id="main-content">
    <div class="mb-6 reveal">
      <span class="inline-block px-4 py-1.5 rounded-full border border-teal/20 bg-teal/5 text-teal text-[10px] font-bold uppercase tracking-[0.2em] mb-8">
        Global EAP Solutions • 180+ Countries
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8 leading-[1.1]" id="heroTitle">
        The World's Most Trusted <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal via-emerald-400 to-teal">Global EAP Provider</span>
      </h1>
    </div>

    <p class="text-slate-400 text-sm md:text-lg max-w-2xl mx-auto leading-relaxed mb-10 reveal" id="heroSubtitle">
      Empowering 35M+ lives with professional, clinically-governed 24/7 support. 
      Where human care meets enterprise scale.
    </p>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-10 max-w-4xl mx-auto" id="heroStats">
      {heroStats.map(stat => (
        <div class="glass-card p-4 md:p-5 rounded-2xl cursor-glow reveal border-white/[0.03]">
          <div
            class="text-xl md:text-3xl font-bold text-teal mb-0.5 stat-number"
            data-value={stat.numericValue}
            data-suffix={stat.suffix}
          >
            {stat.value}
          </div>
          <div class="text-slate-400 text-[10px] md:text-xs font-medium uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal" id="heroCtas">
      <a
        href="#contact"
        class="bg-teal hover:bg-teal-dark text-white px-7 py-3.5 rounded-xl text-base font-semibold transition-all duration-300 hover:scale-105 shadow-lg shadow-teal/10"
      >
        Request Demo
      </a>
      <a
        href="#services"
        class="bg-white/5 border border-white/10 hover:border-teal/50 text-white px-7 py-3.5 rounded-xl text-base font-semibold transition-all duration-300 hover:bg-white/10"
      >
        Learn More
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 scroll-indicator" id="scrollIndicator">
    <a href="#services" class="flex flex-col items-center gap-2 text-gray-400 hover:text-teal transition-colors">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase opacity-50">Scroll</span>
      <svg class="w-5 h-5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(to bottom, #ffffff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
