---
import { services } from '../data/services';

const iconPaths: Record<string, string> = {
  'phone': 'M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z',
  'message-circle': 'M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z',
  'monitor': 'M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z',
  'briefcase': 'M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z',
  'users': 'M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z',
  'pie-chart': 'M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z',
};

const secondaryPaths: Record<string, string> = {
  'briefcase': 'M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z',
  'pie-chart': 'M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z',
};
---

<section id="services" class="py-24 md:py-32 px-4 relative">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Comprehensive <span class="text-teal">Wellbeing Solutions</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-base md:text-lg">
        24/7/365 support across mental health, social, physical and financial pillars with world-class clinical governance.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-12">
      {services.map((service, index) => (
        <div
          class="glass-card p-6 md:p-8 rounded-2xl cursor-glow reveal service-card group"
          style={`--delay: ${index * 100}ms`}
        >
          <!-- Icon -->
          <div class="mb-6">
            <div class="w-14 h-14 bg-teal/10 border border-teal/30 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:bg-teal/20 group-hover:border-teal/50 group-hover:scale-110">
              <svg class="w-7 h-7 text-teal" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d={iconPaths[service.icon]} clip-rule="evenodd"/>
                {secondaryPaths[service.icon] && (
                  <path d={secondaryPaths[service.icon]}/>
                )}
              </svg>
            </div>
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-teal transition-colors duration-300">
            {service.title}
          </h3>
          <p class="text-gray-400 text-sm mb-5 leading-relaxed">
            {service.description}
          </p>

          <!-- Features -->
          <ul class="space-y-2.5">
            {service.features.map(feature => (
              <li class="flex items-center text-sm text-gray-300">
                <svg class="w-4 h-4 text-teal mr-2.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center reveal">
      <a
        href="#contact"
        class="inline-block bg-teal hover:bg-teal-dark text-white px-8 py-4 rounded-xl text-lg font-semibold glow-effect transition-all duration-300 hover:scale-105"
      >
        Get Free Demo
      </a>
    </div>
  </div>
</section>

<script>
  // Cursor-following glow effect on service cards
  document.querySelectorAll('.service-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;
      (card as HTMLElement).style.setProperty('--glow-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--glow-y', `${y}px`);
    });
  });
</script>
