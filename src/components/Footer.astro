---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Results', href: '#results' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Contact', href: '#contact' },
];

const serviceLinks = [
  '24/7 Crisis Support',
  'Structured Counselling',
  'Digital Platform',
  'WorkLife Solutions',
  'OurHealth Community',
  'Analytics Dashboard',
];
---

<footer class="relative pt-20 pb-8 px-4">
  <!-- Separator -->
  <div class="footer-separator mb-16"></div>

  <div class="max-w-7xl mx-auto">
    <!-- Footer Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 mb-16">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center">
            <svg class="w-6 h-6 text-white" viewBox="0 0 100 100" fill="none">
              <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="5"/>
              <ellipse cx="50" cy="50" rx="18" ry="35" stroke="currentColor" stroke-width="5"/>
              <line x1="15" y1="50" x2="85" y2="50" stroke="currentColor" stroke-width="5"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white">Global Team Plans</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Transforming workplace wellbeing across 180+ countries worldwide. Supporting over 35 million lives with comprehensive EAP services.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2.5">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-teal text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold mb-4">Services</h4>
        <ul class="space-y-2.5">
          {serviceLinks.map(service => (
            <li>
              <a href="#services" class="text-gray-400 hover:text-teal text-sm transition-colors duration-200">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contact</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:find@gtpinsurance.gr" class="text-gray-400 hover:text-teal text-sm transition-colors duration-200 flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              find@gtpinsurance.gr
            </a>
          </li>
          <li class="text-gray-400 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            180+ Countries Worldwide
          </li>
          <li class="text-gray-400 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            24/7 Support Available
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} Global Team Plans. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-sm">
        <a href="/privacy" class="text-gray-500 hover:text-teal transition-colors duration-200">Privacy Policy</a>
        <a href="#" class="text-gray-500 hover:text-teal transition-colors duration-200">Terms of Service</a>
      </div>
    </div>
  </div>

  <!-- Back to Top -->
  <button
    id="backToTop"
    class="fixed bottom-8 right-8 w-12 h-12 bg-teal/90 hover:bg-teal rounded-full flex items-center justify-center shadow-lg shadow-teal/20 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none z-40"
    aria-label="Back to top"
  >
    <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>
</footer>

<script>
  const backToTop = document.getElementById('backToTop')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      backToTop.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      backToTop.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
    } else {
      backToTop.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      backToTop.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
    }
  }, { passive: true });

  backToTop.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
