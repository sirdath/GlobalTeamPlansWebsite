---
const navLinks = [
  { label: 'Programme',    href: '#programme' },
  { label: 'Evidence',     href: '#evidence' },
  { label: 'Governance',   href: '#governance' },
  { label: 'Pricing',      href: '#pricing' },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-ink)] focus:text-[var(--color-paper)] focus:px-4 focus:py-2">
  Skip to content
</a>

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50" aria-label="Main navigation">
  <div class="container-prose">
    <div class="flex items-center justify-between h-20 md:h-24" id="navInner">
      <!-- Logo wordmark -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Global Team Plans — home">
        <img
          src="/logo.png"
          alt="Global Team Plans"
          width="320"
          height="72"
          class="h-12 md:h-16 w-auto select-none"
          draggable="false"
        />
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-9">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-[14px] font-semibold text-[var(--color-navy)] hover:text-[var(--color-brand-blue)] transition-colors relative group/link"
          >
            {link.label}
            <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-[var(--color-brand-blue)] transition-all duration-300 group-hover/link:w-full"></span>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="hidden md:block">
        <a href="#contact" class="btn-primary">
          Book a consultation
          <span aria-hidden>→</span>
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobileMenuBtn"
        class="md:hidden relative w-10 h-10 flex items-center justify-center"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <div class="space-y-[5px]" id="hamburgerIcon">
          <span class="block w-6 h-[2px] rounded-full bg-[var(--color-navy)] transition-all duration-300 origin-center"></span>
          <span class="block w-6 h-[2px] rounded-full bg-[var(--color-navy)] transition-all duration-300"></span>
        </div>
      </button>
    </div>
  </div>

  <hr class="rule" id="navRule" style="opacity:0;transition:opacity .25s ease" />

  <!-- Mobile menu -->
  <div
    id="mobileMenu"
    class="fixed inset-0 bg-white z-40 flex flex-col items-start justify-start gap-3 pt-28 px-6 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  >
    {navLinks.map(link => (
      <a
        href={link.href}
        class="mobile-nav-link text-3xl font-bold text-[var(--color-navy)] hover:text-[var(--color-brand-blue)] transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a href="#contact" class="mobile-nav-link mt-8 btn-primary">Book a consultation</a>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const navRule = document.getElementById('navRule')!;
  const mobileMenuBtn = document.getElementById('mobileMenuBtn')!;
  const mobileMenu = document.getElementById('mobileMenu')!;
  const hamburgerSpans = document.querySelectorAll<HTMLSpanElement>('#hamburgerIcon span');
  const mobileNavLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');

  let isMenuOpen = false;

  function handleScroll() {
    const y = window.scrollY;
    if (y > 24) {
      navbar.style.background = 'rgba(255, 255, 255, 0.92)';
      navbar.style.backdropFilter = 'saturate(140%) blur(8px)';
      (navbar.style as any).webkitBackdropFilter = 'saturate(140%) blur(8px)';
      navRule.style.opacity = '1';
    } else {
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = 'none';
      (navbar.style as any).webkitBackdropFilter = 'none';
      navRule.style.opacity = '0';
    }
  }

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    mobileMenuBtn.setAttribute('aria-expanded', String(isMenuOpen));
    if (isMenuOpen) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
      hamburgerSpans[0].style.transform = 'translateY(3px) rotate(45deg)';
      hamburgerSpans[1].style.transform = 'translateY(-3px) rotate(-45deg)';
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
      hamburgerSpans[0].style.transform = '';
      hamburgerSpans[1].style.transform = '';
    }
  }

  mobileNavLinks.forEach(link => link.addEventListener('click', () => { if (isMenuOpen) toggleMenu(); }));
  mobileMenuBtn.addEventListener('click', toggleMenu);
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
