---
const navLinks = [
  { label: 'Programme',  href: '#programme',  num: '01', accent: 'blue'  },
  { label: 'Evidence',   href: '#evidence',   num: '02', accent: 'green' },
  { label: 'Governance', href: '#governance', num: '03', accent: 'gold'  },
  { label: 'Pricing',    href: '#pricing',    num: '04', accent: 'blue'  },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-[var(--color-navy)] focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
  Skip to content
</a>

<nav id="navbar" class="navbar fixed top-0 left-0 right-0 z-50" aria-label="Main navigation" data-menu-open="false">
  <div class="w-full">
    <div class="flex items-center justify-between gap-3 h-16 md:h-[72px] pl-4 sm:pl-6 md:pl-8 lg:pl-10 pr-4 sm:pr-6 md:pr-10 lg:pr-14" id="navInner">
      <!-- Logo wordmark -->
      <a href="/" class="flex items-center gap-3 group min-w-0 shrink relative z-[60]" aria-label="Global Team Plans — home">
        <img
          src="/logo.png"
          alt="Global Team Plans"
          width="260"
          height="21"
          class="h-[16px] sm:h-[18px] md:h-[20px] lg:h-[24px] w-auto max-w-full select-none shrink-0"
          draggable="false"
          decoding="async"
          fetchpriority="high"
        />
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-5 lg:gap-9 shrink-0">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-[13px] lg:text-[14px] font-semibold text-[var(--color-navy)] hover:text-[var(--color-brand-blue)] transition-colors relative group/link whitespace-nowrap"
          >
            {link.label}
            <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-[var(--color-brand-blue)] transition-all duration-300 group-hover/link:w-full"></span>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="hidden md:block shrink-0">
        <a href="#contact" class="btn-primary nav-cta">
          <span class="lg:hidden">Book demo</span>
          <span class="hidden lg:inline">Book a consultation</span>
          <span aria-hidden>→</span>
        </a>
      </div>

      <!-- Mobile hamburger / close toggle (44×44) -->
      <button
        id="mobileMenuBtn"
        class="hamburger md:hidden relative z-[60] w-11 h-11 flex items-center justify-center -mr-1 shrink-0"
        aria-label="Open navigation menu"
        aria-controls="mobileMenu"
        aria-expanded="false"
        type="button"
      >
        <span class="hamburger-box" aria-hidden="true">
          <span class="hamburger-line hamburger-line-1"></span>
          <span class="hamburger-line hamburger-line-2"></span>
          <span class="hamburger-line hamburger-line-3"></span>
        </span>
      </button>
    </div>
  </div>

  <hr class="rule navbar-rule" id="navRule" />

  <!-- Mobile menu -->
  <div
    id="mobileMenu"
    class="mobile-menu md:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Site navigation"
  >
    <div class="mobile-menu-inner">
      <!-- Tri-color brand rail -->
      <span class="mobile-menu-rail" aria-hidden="true">
        <span style="background: var(--color-brand-blue)"></span>
        <span style="background: var(--color-brand-green)"></span>
        <span style="background: var(--color-brand-gold)"></span>
      </span>

      <!-- Links with brand-color numerals -->
      <nav class="mobile-menu-links" aria-label="Mobile">
        {navLinks.map((link) => (
          <a href={link.href} class="mobile-link" data-mobile-link>
            <span class={`mobile-link-num mobile-link-num-${link.accent}`}>{link.num}</span>
            <span class="mobile-link-label">{link.label}</span>
            <span class="mobile-link-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a href="#contact" class="mobile-cta btn-primary" data-mobile-link>
        Book a consultation
        <span aria-hidden>→</span>
      </a>

      <!-- Contact strip -->
      <div class="mobile-menu-contact">
        <div class="eyebrow eyebrow-mute mb-1">Direct</div>
        <a class="link-underline" href="mailto:find@gtpinsurance.gr" data-mobile-link>find@gtpinsurance.gr</a>
        <div class="mt-3 text-[13px] text-[var(--color-ink-mute)]">Athens, Greece · TELUS&nbsp;Health partner</div>
      </div>

      <!-- Footer brand rail -->
      <div class="mobile-menu-footer">
        <span class="tri-rule"><span class="b1"></span><span class="b2"></span><span class="b3"></span></span>
        <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-mute)]">Global · Team · Plans</span>
      </div>
    </div>
  </div>
</nav>

<style>
  /* ── Navbar scroll state (toggled by a class, not inline styles) ── */
  .navbar { transition: background 0.25s ease, box-shadow 0.25s ease; }
  /* Solid translucent white (no backdrop blur — far cheaper to repaint on scroll) */
  .navbar.is-scrolled {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 1px 0 rgba(18, 50, 74, 0.06);
  }
  .navbar-rule { opacity: 0; transition: opacity 0.25s ease; }
  .navbar.is-scrolled .navbar-rule { opacity: 1; }
  /* When the mobile menu is open, force an opaque nav bar so the logo/X read cleanly */
  .navbar[data-menu-open="true"] { background: #FFFFFF; }

  /* ── Hamburger → X (3 lines, reliable transform) ── */
  .hamburger-box {
    position: relative;
    width: 24px;
    height: 16px;
    display: block;
  }
  .hamburger-line {
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    border-radius: 2px;
    background: var(--color-navy);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease, background 0.2s ease;
  }
  .hamburger-line-1 { top: 0; }
  .hamburger-line-2 { top: 7px; }
  .hamburger-line-3 { top: 14px; }

  .navbar[data-menu-open="true"] .hamburger-line-1 { transform: translateY(7px) rotate(45deg); }
  .navbar[data-menu-open="true"] .hamburger-line-2 { opacity: 0; transform: scaleX(0); }
  .navbar[data-menu-open="true"] .hamburger-line-3 { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile menu panel ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: #FFFFFF;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.28s ease, transform 0.28s ease, visibility 0s linear 0.28s;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .navbar[data-menu-open="true"] .mobile-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.28s ease, transform 0.28s ease, visibility 0s linear 0s;
  }

  .mobile-menu-inner {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    padding: calc(5.5rem + env(safe-area-inset-top)) 1.5rem calc(2rem + env(safe-area-inset-bottom));
  }

  .mobile-menu-rail {
    display: flex;
    height: 4px;
    width: 56px;
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .mobile-menu-rail > span { flex: 1; }

  /* Links */
  .mobile-menu-links {
    display: flex;
    flex-direction: column;
  }
  .mobile-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-rule);
    color: var(--color-navy);
    text-decoration: none;
    /* staggered entrance */
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease, color 0.2s ease;
  }
  .navbar[data-menu-open="true"] .mobile-link { opacity: 1; transform: translateY(0); }
  .navbar[data-menu-open="true"] .mobile-link:nth-child(1) { transition-delay: 0.08s; }
  .navbar[data-menu-open="true"] .mobile-link:nth-child(2) { transition-delay: 0.13s; }
  .navbar[data-menu-open="true"] .mobile-link:nth-child(3) { transition-delay: 0.18s; }
  .navbar[data-menu-open="true"] .mobile-link:nth-child(4) { transition-delay: 0.23s; }

  .mobile-link:active { color: var(--color-brand-blue); }
  .mobile-link-num {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    min-width: 1.5rem;
  }
  .mobile-link-num-blue  { color: var(--color-brand-blue); }
  .mobile-link-num-green { color: var(--color-brand-green-dark); }
  .mobile-link-num-gold  { color: var(--color-brand-gold-dark); }
  .mobile-link-label {
    flex: 1;
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .mobile-link-arrow {
    color: var(--color-ink-faint);
    font-size: 1.25rem;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .mobile-link:active .mobile-link-arrow { transform: translateX(4px); color: var(--color-brand-blue); }

  /* CTA */
  .mobile-cta {
    margin-top: 2rem;
    width: 100%;
    justify-content: center;
    font-size: 16px;
    padding-block: 1rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease 0.3s, transform 0.4s ease 0.3s, background 0.2s ease;
  }
  .navbar[data-menu-open="true"] .mobile-cta { opacity: 1; transform: translateY(0); }

  /* Contact + footer */
  .mobile-menu-contact {
    margin-top: 2.5rem;
    opacity: 0;
    transition: opacity 0.4s ease 0.36s;
  }
  .navbar[data-menu-open="true"] .mobile-menu-contact { opacity: 1; }

  .mobile-menu-footer {
    margin-top: auto;
    padding-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .mobile-link,
    .mobile-cta,
    .mobile-menu-contact { transition-duration: 0.01ms !important; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement;
  const menuBtn = document.getElementById('mobileMenuBtn') as HTMLButtonElement;
  const menu = document.getElementById('mobileMenu') as HTMLElement;
  const menuLinks = document.querySelectorAll<HTMLElement>('[data-mobile-link]');

  let isOpen = false;
  let scrollY = 0;

  // ── Scroll state via class (cheap, no per-frame inline writes) ──
  let ticking = false;
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      navbar.classList.toggle('is-scrolled', window.scrollY > 24);
      ticking = false;
    });
  }

  function openMenu() {
    isOpen = true;
    scrollY = window.scrollY;
    navbar.setAttribute('data-menu-open', 'true');
    menuBtn.setAttribute('aria-expanded', 'true');
    menuBtn.setAttribute('aria-label', 'Close navigation menu');
    // lock body scroll without losing position
    document.body.style.position = 'fixed';
    document.body.style.top = `-${scrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';
  }

  function closeMenu() {
    isOpen = false;
    navbar.setAttribute('data-menu-open', 'false');
    menuBtn.setAttribute('aria-expanded', 'false');
    menuBtn.setAttribute('aria-label', 'Open navigation menu');
    // restore scroll
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';
    window.scrollTo(0, scrollY);
  }

  function toggleMenu() {
    if (isOpen) closeMenu();
    else openMenu();
  }

  menuBtn.addEventListener('click', toggleMenu);
  menuLinks.forEach((link) =>
    link.addEventListener('click', () => {
      if (isOpen) closeMenu();
    })
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeMenu();
      menuBtn.focus();
    }
  });
  // Close if resized up to desktop while open
  window.matchMedia('(min-width: 768px)').addEventListener('change', (e) => {
    if (e.matches && isOpen) closeMenu();
  });

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
