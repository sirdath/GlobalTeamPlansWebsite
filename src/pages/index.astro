  </footer>

  <!-- Plan select + form submit -->
  <script is:inline>
    var selectedPlan = '';
    document.querySelectorAll('.plan-select-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        selectedPlan = this.getAttribute('data-plan');
        var sp = document.getElementById('selectedPlan');
        if (sp) sp.textContent = 'Discussing ' + selectedPlan;
        var c = document.getElementById('contact');
        if (c) c.scrollIntoView({ behavior: 'smooth' });
      });
    });

    var form = document.getElementById('demoForm');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var fd = new FormData(e.target);
        var d = {};
        fd.forEach(function (v, k) { d[k] = v; });

        var subject = 'TELUS Health EAP — Consultation request — ' + (d.companyName || 'New enquiry');
        var lines = [
          'Hello GTP,',
          '',
          'I would like to book a consultation about the TELUS Health Employee Assistance Programme.',
          '',
          'Contact',
          '  Name      : ' + (d.firstName || '') + ' ' + (d.lastName || ''),
          '  Email     : ' + (d.workEmail || ''),
          '  Phone     : ' + (d.phone || ''),
          '  Role      : ' + (d.role || ''),
          '',
          'Company',
          '  Name      : ' + (d.companyName || ''),
          '  Employees : ' + (d.employees || ''),
          '  Countries : ' + (d.countries || ''),
          '',
          (selectedPlan ? 'Indicative tier: ' + selectedPlan : ''),
          '',
          (d.message ? 'Notes: ' + d.message : ''),
          '',
          'Best regards,',
          (d.firstName || '') + ' ' + (d.lastName || '')
        ];
        var body = lines.filter(function (l) { return l !== null; }).join('\n');
        window.location.href = 'mailto:find@gtpinsurance.gr?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
        e.target.reset();
        var sp = document.getElementById('selectedPlan');
        if (sp) sp.textContent = '';
        selectedPlan = '';
      });
    }
  </script>
</BaseLayout>
