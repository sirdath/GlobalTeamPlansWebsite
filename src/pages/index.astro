---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { pricing, pricingNote } from '../data/pricing';
import {
  // Programme
  LifeBuoy, MessagesSquare, Smartphone, Briefcase, UsersRound, LineChart,
  // Governance
  Stethoscope, ShieldCheck, Fingerprint, Gauge,
  // Partnership trio
  Handshake, Globe, FileText,
  // Contact
  Mail, MapPin, Network,
  // Who we help
  Building2, Users, ClipboardList,
  // Why GTP
  BadgeCheck, Globe2, HeartHandshake,
} from 'lucide-astro';

const programmeIcons: Record<string, any> = {
  crisis:      LifeBuoy,
  counselling: MessagesSquare,
  digital:     Smartphone,
  worklife:    Briefcase,
  community:   UsersRound,
  analytics:   LineChart,
};

const pageTitle = "Global Team Plans — Global employee wellbeing, made simple";
const pageDescription = "Global Team Plans helps companies access trusted global health, wellbeing, and EAP programmes — delivered as a certified TELUS Health partner agency across 180+ countries.";

// Programme — what's included
const programme = [
  { num: '01', title: '24/7 crisis & critical-incident response', body: 'Immediate phone and video access to qualified counsellors for safety events, workplace incidents, bereavement, and disaster response. Available in 50+ languages, in-country routing where it matters.', visual: 'crisis',      key: 'Answer ≤ 60s · 50+ languages · in-country routing' },
  { num: '02', title: 'Structured counselling',                  body: 'Short-term modalities — 1:1 in-person, video, or telephonic — for what actually shows up in a workforce: anxiety, low mood, sleep, substance use, relationship strain. Sessions tracked, outcomes measured.', visual: 'counselling', key: '5 sessions / member / year · PHQ-9 + GAD-7 outcomes' },
  { num: '03', title: 'Digital wellbeing platform',              body: 'Consumer-grade app: self-guided CBT programmes, an assessed content library, and the Total Wellbeing Index that points members to the right support before they need crisis care.', visual: 'digital',     key: 'iOS · Android · Web · self-guided CBT' },
  { num: '04', title: 'WorkLife services',                       body: 'Legal consultations, financial planning, childcare and eldercare navigation, and nutritional coaching. The part of an EAP that quietly removes more friction than counselling alone.', visual: 'worklife',    key: 'Legal · Financial · Care · same-week booking' },
  { num: '05', title: 'OurHealth peer community',                body: 'Anonymous peer-to-peer forum, professionally moderated, available in 30+ languages. A first step for members who are not yet ready to talk to a clinician.', visual: 'community',   key: '30+ languages · pro-moderated 24/7' },
  { num: '06', title: 'HR analytics & utilisation dashboard',    body: 'Aggregate, anonymised reporting for HR: utilisation, modality mix, presenting issues, and demographic trends. Quarterly business reviews with named account management.', visual: 'analytics',   key: 'Monthly + quarterly reviews · named account team' },
];

// Brand-color layout across the 6 tiles — balanced so no two adjacent tiles
// share a colour (row1: blue green gold · row2: gold blue green).
const programmeAccents = ['blue', 'green', 'gold', 'gold', 'blue', 'green'];

const whoWeHelp = [
  {
    icon: Building2,
    accent: 'blue',
    title: 'Employers',
    body: 'Procurement-ready EAP for organisations whose people don\'t all sit in the same country. One contract, consistent governance, locally-licensed delivery.',
  },
  {
    icon: Users,
    accent: 'green',
    title: 'Global teams',
    body: 'Distributed and remote workforces, multilingual teams, and employees crossing borders on assignment. Equal access, in their language and timezone.',
  },
  {
    icon: ClipboardList,
    accent: 'gold',
    title: 'HR & benefits leaders',
    body: 'Comparable reporting cohort to cohort, named account management, and the paperwork your legal and procurement teams already know how to process.',
  },
];

const whyGtp = [
  {
    icon: BadgeCheck,
    bar: 'blue',
    title: 'Trusted providers',
    body: 'We sell the full TELUS Health Employee Assistance Programme — accredited by the Council on Accreditation, run under one global clinical model.',
  },
  {
    icon: Globe2,
    bar: 'green',
    title: 'Global reach',
    body: 'One contract covers 180+ countries and 50+ languages. In-country counsellors, in-language platforms, consistent SLAs.',
  },
  {
    icon: HeartHandshake,
    bar: 'gold',
    title: 'Human support',
    body: 'You get the contract, the local relationship, and someone who answers your email on Athens time. The clinical service stays clinical.',
  },
];

// Footnotes / sources
const sources = [
  { n: 1, label: 'TELUS Health EAP delivery footprint — 35M+ lives, 180+ countries, 50+ languages.', url: 'https://www.telushealth.com/', publisher: 'TELUS Health' },
  { n: 2, label: 'TELUS Health Mental Health Index — workplace outcomes for participating employee populations.', url: 'https://www.telushealth.com/health-insights', publisher: 'TELUS Health Insights' },
  { n: 3, label: 'Council on Accreditation (COA) — clinical governance standard held by TELUS Health.', url: 'https://coanet.org/', publisher: 'Council on Accreditation' },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Nav />

  <main>
    <Hero />

    <!-- ============================================================
         WHO WE HELP — three audience cards (blue / green / gold)
         ============================================================ -->
    <section id="audience" class="section section-soft section-brand-top stripe-tri">
      <div class="container-prose">
        <div class="max-w-2xl mb-14" data-reveal="up">
          <SectionEyebrow label="Who we help" accent="blue" />
          <h2 data-split class="text-[clamp(1.9rem,3.3vw,2.75rem)] leading-[1.1] tracking-[-0.02em]">
            Built for the people who actually <span class="accent-hl">buy and run</span> EAP programmes.
          </h2>
        </div>

        <div class="grad-grid" id="audienceGrid">
          {whoWeHelp.map((a, i) => {
            const Ico = a.icon;
            return (
              <article class={`grad-tile grad-${a.accent}`} data-grad-tile>
                <span class="grad-icon"><Ico size={26} strokeWidth={1.85} /></span>
                <h3 class="grad-title">{a.title}</h3>
                <p class="grad-body">{a.body}</p>
              </article>
            );
          })}
        </div>
      </div>

      <script is:inline>
        (function () {
          function start() {
            var tiles = Array.prototype.slice.call(document.querySelectorAll('#audienceGrid [data-grad-tile]'));
            if (!tiles.length) return;
            var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (window.gsap && !reduced) {
              window.gsap.set(tiles, { opacity: 0, y: 30, scale: 0.94 });
              window.gsap.to(tiles, {
                opacity: 1, y: 0, scale: 1, duration: 0.65, ease: 'power3.out',
                stagger: 0.12,
                scrollTrigger: { trigger: '#audienceGrid', start: 'top 82%', once: true },
              });
            } else {
              tiles.forEach(function (t) { t.style.opacity = '1'; });
            }
          }
          if (document.readyState !== 'loading') start();
          else document.addEventListener('DOMContentLoaded', start);
        })();
      </script>
    </section>

    <!-- ============================================================
         PARTNERSHIP — agency story + dotted world map
         ============================================================ -->
    <section id="partnership" class="section section-white section-brand-top stripe-blue">
      <div class="container-prose grid md:grid-cols-12 gap-x-12 gap-y-14">

        <div class="md:col-span-5 md:sticky md:top-32 self-start" data-reveal="up">
          <SectionEyebrow label="About this partnership" accent="blue" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]">
            We sell <span class="accent-hl-green">TELUS&nbsp;Health</span>. We don't pretend we're them.
          </h2>
          <p class="lede mt-6">
            Global Team Plans is a certified TELUS&nbsp;Health partner agency, headquartered in Athens. We sell, implement, and account-manage the TELUS&nbsp;Health Employee Assistance Programme for organisations whose people don't all sit in the same country.
          </p>
          <p class="mt-4 text-[15px] text-[var(--color-ink-soft)] leading-relaxed">
            The clinical service, the digital platform, the 24/7 counsellor network — all built and run by TELUS&nbsp;Health, one of the largest EAP providers in the world. What you get from us is the contract, the local relationship, the procurement-friendly paperwork, and someone who answers your email on Athens time.
          </p>
        </div>

        <div class="md:col-span-7" data-reveal="up" data-reveal-delay="0.15">
          <div class="world-map world-map-light world-map-gtp" id="partnership-map"></div>

          <!-- Coverage stat: 180 of 195 countries -->
          <div class="mt-6 grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-x-8 gap-y-4 items-end">
            <div class="coverage-stat">
              <span class="cs-num"><span data-count-up="180">180</span></span>
              <span class="cs-of">of 195 countries</span>
            </div>
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="eyebrow eyebrow-green">Global coverage</span>
                <span class="text-[13px] font-bold text-[var(--color-brand-green-dark)]">92%</span>
              </div>
              <div class="coverage-bar" id="coverageBar"><span></span></div>
            </div>
          </div>
          <p class="mt-4 text-[12px] text-[var(--color-ink-mute)]">
            The TELUS&nbsp;Health delivery network reaches 180 of the world's 195 countries and territories<sup class="fn-ref"><a href="#footnotes">1</a></sup>.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-10 pt-8 border-t border-[var(--color-rule)]">
            <div>
              <span class="icon-square icon-square-blue mb-3"><Handshake size={20} strokeWidth={1.75} /></span>
              <div class="eyebrow eyebrow-mute mb-2">Agency role</div>
              <div class="text-[1rem] leading-snug font-semibold">Contracting, implementation, account management</div>
            </div>
            <div>
              <span class="icon-square icon-square-green mb-3"><Globe size={20} strokeWidth={1.75} /></span>
              <div class="eyebrow eyebrow-mute mb-2">Clinical delivery</div>
              <div class="text-[1rem] leading-snug font-semibold">TELUS&nbsp;Health network, in-country</div>
            </div>
            <div>
              <span class="icon-square icon-square-gold mb-3"><FileText size={20} strokeWidth={1.75} /></span>
              <div class="eyebrow eyebrow-mute mb-2">Contract term</div>
              <div class="text-[1rem] leading-snug font-semibold">36-month standard, custom available</div>
            </div>
          </div>
        </div>
      </div>

      <script is:inline>
        (function () {
          function start() {
            if (!window.WorldMap) return setTimeout(start, 50);
            var mapEl = document.getElementById('partnership-map');
            var sub = (mapEl && mapEl.clientWidth < 520) ? 2 : 3; // far fewer SVG nodes
            window.WorldMap.init('#partnership-map', {
              dots: [],
              coverage: [],         // no overlay markers — clean green halftone landmass
              subdivide: sub,       // halftone continents (2 on mobile, 3 on desktop)
              density: 1.05,        // slightly larger dots to keep the fill dense at lower count
            });
          }
          if (document.readyState !== 'loading') start();
          else document.addEventListener('DOMContentLoaded', start);

          // Fill the coverage bar when it scrolls into view
          function fillBar() {
            var bar = document.getElementById('coverageBar');
            if (!bar) return;
            var io = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) { bar.classList.add('is-filled'); io.unobserve(bar); }
              });
            }, { threshold: 0.4 });
            io.observe(bar);
          }
          if (document.readyState !== 'loading') fillBar();
          else document.addEventListener('DOMContentLoaded', fillBar);
        })();
      </script>
    </section>

    <!-- ============================================================
         PROGRAMME — 6-card grid with hover-tilt
         ============================================================ -->
    <section id="programme" class="section section-soft section-brand-top stripe-green">
      <div class="container-prose">
        <div class="max-w-2xl mb-14">
          <SectionEyebrow label="The programme" accent="green" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]">
            What's actually <span class="accent-hl-green">in the box</span>.
          </h2>
          <p data-reveal="up" data-reveal-delay="0.15" class="lede mt-6">
            Six service lines, one contract. Designed for HR teams who need consistency across borders and the audit trail to prove it.
          </p>
        </div>

        <!-- Photo cards with brand-duotone media (gradient placeholder until real photos drop in) -->
        <div class="prog-photogrid" data-reveal-stagger>
          {programme.map((item, i) => {
            const Icon   = programmeIcons[item.visual];
            const accent = programmeAccents[i];
            return (
              <article class={`prog-pc prog-pc-${accent}`}>
                <div class="prog-pc-media">
                  <img
                    src={`/programme/prog-${item.visual}.webp`}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    onerror="this.style.display='none'"
                  />
                  <span class="prog-pc-icon"><Icon size={20} strokeWidth={1.9} /></span>
                  <span class="prog-pc-num" aria-hidden="true">{item.num}</span>
                </div>
                <div class="prog-pc-body">
                  <h3 class="prog-pc-title">{item.title}</h3>
                  <p class="prog-pc-text">{item.body}</p>
                  <p class="prog-pc-key">{item.key}</p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ============================================================
         WHY GTP — white bg, navy text, brand-tinted cards
         ============================================================ -->
    <section id="why" class="section section-white section-brand-top stripe-tri">
      <div class="container-prose">
        <div class="max-w-2xl mb-14" data-reveal="up">
          <SectionEyebrow label="Why Global Team Plans" accent="navy" withMark={true} class="seye-lg" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]" style="color: var(--color-navy);">
            A calm, trustworthy partner — for people who take wellbeing seriously.
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6" data-reveal-stagger>
          {whyGtp.map((p, i) => {
            const Ico    = p.icon;
            const accent = p.bar;
            return (
              <div class={`solid-tile solid-${accent} h-full flex flex-col`}>
                <span class="solid-icon"><Ico size={24} strokeWidth={1.85} /></span>
                <h3 class="solid-title">{p.title}</h3>
                <p class="solid-body">{p.body}</p>
              </div>
            );
          })}
        </div>

        <!-- Tri-colour rail -->
        <div class="mt-16 flex items-center gap-4 text-[12px] text-[var(--color-ink-mute)]">
          <span class="tri-rule"><span class="b1"></span><span class="b2"></span><span class="b3"></span></span>
          <span class="uppercase tracking-[0.18em]">Global &nbsp;·&nbsp; Team &nbsp;·&nbsp; Plans</span>
        </div>
      </div>
    </section>

    <!-- ============================================================
         EVIDENCE — ROI numbers with citations
         ============================================================ -->
    <section id="evidence" class="section section-white section-brand-top stripe-gold">
      <div class="container-prose">
        <div class="max-w-2xl mb-16" data-reveal="up">
          <SectionEyebrow label="Evidence" accent="gold" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]">
            What the data actually <span class="accent-hl">shows</span>.
          </h2>
          <p class="lede mt-6">
            Workplace outcomes from TELUS&nbsp;Health's Mental Health Index for employee populations using the programme. Sourced, not invented.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-x-12 gap-y-12" data-reveal-stagger>
          <div>
            <div class="text-[clamp(3.5rem,6.5vw,5rem)] leading-none tracking-[-0.04em] font-bold text-[var(--color-brand-blue)]">
              <span data-count-up="50" data-count-suffix="%">50%</span>
            </div>
            <div class="mt-3 h-[3px] w-12 rounded-sm" style="background: var(--color-brand-blue);"></div>
            <div class="mt-4 text-[15px] leading-snug text-[var(--color-ink-soft)]">
              Reduction in employees rating their mental health as poor<sup class="fn-ref"><a href="#footnotes">2</a></sup>
            </div>
          </div>

          <div>
            <div class="text-[clamp(3.5rem,6.5vw,5rem)] leading-none tracking-[-0.04em] font-bold text-[var(--color-brand-green-dark)]">
              <span data-count-up="38" data-count-suffix="%">38%</span>
            </div>
            <div class="mt-3 h-[3px] w-12 rounded-sm" style="background: var(--color-brand-green);"></div>
            <div class="mt-4 text-[15px] leading-snug text-[var(--color-ink-soft)]">
              Drop in presenteeism hours among participating employees<sup class="fn-ref"><a href="#footnotes">2</a></sup>
            </div>
          </div>

          <div>
            <div class="text-[clamp(3.5rem,6.5vw,5rem)] leading-none tracking-[-0.04em] font-bold text-[var(--color-brand-gold-dark)]">
              <span data-count-up="42" data-count-suffix="%">42%</span>
            </div>
            <div class="mt-3 h-[3px] w-12 rounded-sm" style="background: var(--color-brand-gold);"></div>
            <div class="mt-4 text-[15px] leading-snug text-[var(--color-ink-soft)]">
              Increase in employees rating their mental health as good<sup class="fn-ref"><a href="#footnotes">2</a></sup>
            </div>
          </div>
        </div>

        <p class="mt-12 text-[13px] text-[var(--color-ink-mute)] max-w-2xl">
          These are outcomes from TELUS&nbsp;Health's published Mental Health Index data, not GTP marketing figures. Numbers vary by industry, region, and baseline; your account team will share comparable cohort data during the proposal stage.
        </p>
      </div>
    </section>

    <!-- ============================================================
         GOVERNANCE — A1..A4 compliance cards
         ============================================================ -->
    <section id="governance" class="section section-soft section-brand-top stripe-blue">
      <div class="container-prose">
        <div class="max-w-2xl mb-14" data-reveal="up">
          <SectionEyebrow label="Governance & compliance" accent="navy" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]">
            What your procurement, legal, and IT teams will actually <span class="accent-hl">ask about</span>.
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6" data-reveal-stagger>
          <div class="card-soft accent-top-blue" data-tilt data-tilt-max="4">
            <div class="flex items-center gap-4 mb-4">
              <span class="icon-square icon-square-blue"><Stethoscope size={22} strokeWidth={1.75} /></span>
              <span class="font-mono text-[12px] tracking-widest text-[var(--color-ink-mute)]">A1</span>
            </div>
            <h3 class="text-[1.25rem] tracking-tight mb-3">Clinical governance</h3>
            <p class="text-[15px] leading-relaxed text-[var(--color-ink-soft)]">
              TELUS&nbsp;Health is accredited by the <a class="link-underline" href="https://coanet.org/" target="_blank" rel="noopener">Council on Accreditation</a><sup class="fn-ref"><a href="#footnotes">3</a></sup>. Counsellors are locally licensed, supervised under one global clinical model, with case escalation paths defined at contract signing.
            </p>
          </div>

          <div class="card-soft accent-top-green" data-tilt data-tilt-max="4">
            <div class="flex items-center gap-4 mb-4">
              <span class="icon-square icon-square-green"><ShieldCheck size={22} strokeWidth={1.75} /></span>
              <span class="font-mono text-[12px] tracking-widest text-[var(--color-ink-mute)]">A2</span>
            </div>
            <h3 class="text-[1.25rem] tracking-tight mb-3">Data protection — GDPR & equivalents</h3>
            <p class="text-[15px] leading-relaxed text-[var(--color-ink-soft)]">
              Member-level data is held under strict confidentiality. Aggregate HR reporting only — no identifying information leaves the clinical system. Data Processing Agreement and Standard Contractual Clauses available pre-contract.
            </p>
          </div>

          <div class="card-soft accent-top-gold" data-tilt data-tilt-max="4">
            <div class="flex items-center gap-4 mb-4">
              <span class="icon-square icon-square-gold"><Fingerprint size={22} strokeWidth={1.75} /></span>
              <span class="font-mono text-[12px] tracking-widest text-[var(--color-ink-mute)]">A3</span>
            </div>
            <h3 class="text-[1.25rem] tracking-tight mb-3">Information security</h3>
            <p class="text-[15px] leading-relaxed text-[var(--color-ink-soft)]">
              TELUS&nbsp;Health operates an ISO&nbsp;27001-aligned information security programme. SSO (SAML/OIDC) and member-eligibility integrations are standard. Penetration test summaries available under NDA.
            </p>
          </div>

          <div class="card-soft accent-top-blue" data-tilt data-tilt-max="4">
            <div class="flex items-center gap-4 mb-4">
              <span class="icon-square icon-square-blue"><Gauge size={22} strokeWidth={1.75} /></span>
              <span class="font-mono text-[12px] tracking-widest text-[var(--color-ink-mute)]">A4</span>
            </div>
            <h3 class="text-[1.25rem] tracking-tight mb-3">Service-level commitments</h3>
            <p class="text-[15px] leading-relaxed text-[var(--color-ink-soft)]">
              24/7/365 helpline availability. Crisis-call answer-time targets, first-counselling-session lead-times, and platform uptime defined in your master service agreement. Quarterly business reviews against the SLA.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         PRICING
         ============================================================ -->
    <section id="pricing" class="section section-white section-brand-top stripe-green">
      <div class="container-prose">
        <div class="grid md:grid-cols-12 gap-x-12 gap-y-10 mb-14">
          <div class="md:col-span-5" data-reveal="up">
            <SectionEyebrow label="Pricing" accent="blue" />
            <h2 data-split class="text-[clamp(2rem,3.5vw,3.25rem)] leading-[1.05] tracking-[-0.02em]">
              Per employee, per year. <span class="accent-hl-green">No surprises.</span>
            </h2>
          </div>
          <div class="md:col-span-6 md:col-start-7 md:pt-6" data-reveal="up" data-reveal-delay="0.12">
            <p class="text-[15px] leading-relaxed text-[var(--color-ink-soft)]">
              Two standard tiers cover most enterprises up to 3,000 employees. Above that, pricing moves to a custom band with negotiated language coverage, integrations, and SLA terms. {pricingNote}
            </p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6" data-reveal-stagger>
          {pricing.map((plan, idx) => (
            <div class={"card-soft " + (plan.popular ? 'accent-top-blue' : '')} data-tilt data-tilt-max="3">
              {plan.popular && (
                <div class="mb-4">
                  <span class="tag-gold">Most enterprises pick this</span>
                </div>
              )}
              <div class="eyebrow eyebrow-mute">{plan.subtitle}</div>
              <h3 class="text-[1.5rem] mt-2 tracking-tight">{plan.name}</h3>

              <div class="mt-7 flex items-baseline gap-2">
                <span class="text-[3.25rem] leading-none tracking-[-0.03em] font-bold text-[var(--color-navy)]">{plan.currency}{plan.priceYearly}</span>
                <span class="text-[13px] text-[var(--color-ink-mute)]">/ employee / year</span>
              </div>
              <div class="mt-2 text-[13px] text-[var(--color-ink-mute)]">
                ≈ {plan.currency}{plan.priceMonthly} / employee / month
              </div>

              <ul class="mt-7 space-y-3 flex-grow">
                {plan.features.map(feature => (
                  <li class="flex items-start text-[14px] leading-snug text-[var(--color-ink-soft)]">
                    <span aria-hidden class="mr-3 mt-[8px] inline-block w-3 h-[2px] rounded-sm" style="background: var(--color-brand-green);"></span>
                    {feature}
                  </li>
                ))}
              </ul>

              <button
                data-plan={plan.name}
                class={"plan-select-btn mt-8 self-start " + (plan.popular ? 'btn-primary' : 'btn-secondary')}
              >
                Discuss {plan.name}
                <span aria-hidden>→</span>
              </button>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         CONTACT — Book a consultation
         ============================================================ -->
    <section id="contact" class="section section-soft section-brand-top stripe-tri">
      <div class="container-prose grid md:grid-cols-12 gap-x-12 gap-y-12">

        <div class="md:col-span-5" data-reveal="up">
          <SectionEyebrow label="Book a consultation" accent="blue" />
          <h2 data-split class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.05] tracking-[-0.02em]">
            Tell us where your people are. We'll come back with a proposal.
          </h2>
          <p class="lede mt-6">
            Typical turnaround is three working days. Greek, English, German.
          </p>
          <div class="mt-10 pt-8 border-t border-[var(--color-rule)] space-y-5 text-[14px] text-[var(--color-ink-soft)]">
            <div class="flex items-start gap-3">
              <span class="icon-square icon-square-blue" style="width:36px;height:36px;"><Mail size={18} strokeWidth={1.75} /></span>
              <div>
                <div class="eyebrow eyebrow-mute mb-1">Direct</div>
                <a class="link-underline" href="mailto:find@gtpinsurance.gr">find@gtpinsurance.gr</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="icon-square icon-square-green" style="width:36px;height:36px;"><MapPin size={18} strokeWidth={1.75} /></span>
              <div>
                <div class="eyebrow eyebrow-mute mb-1">Headquarters</div>
                Athens, Greece
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="icon-square icon-square-gold" style="width:36px;height:36px;"><Network size={18} strokeWidth={1.75} /></span>
              <div>
                <div class="eyebrow eyebrow-mute mb-1">Delivery</div>
                TELUS&nbsp;Health network — 180+ countries
              </div>
            </div>
          </div>
        </div>

        <form id="demoForm" class="md:col-span-7 card-soft" style="padding: 2rem;">
          <div id="selectedPlan" class="eyebrow eyebrow-blue mb-6" style="min-height: 1em;"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4 mb-2">
            <label class="block" for="f-firstName">
              <span class="eyebrow eyebrow-mute block mb-2">First name</span>
              <input id="f-firstName" type="text" name="firstName" required class="field" placeholder="Maria" autocomplete="given-name" enterkeyhint="next" />
            </label>
            <label class="block" for="f-lastName">
              <span class="eyebrow eyebrow-mute block mb-2">Last name</span>
              <input id="f-lastName" type="text" name="lastName" required class="field" placeholder="Papadopoulos" autocomplete="family-name" enterkeyhint="next" />
            </label>
            <label class="block" for="f-workEmail">
              <span class="eyebrow eyebrow-mute block mb-2">Work email</span>
              <input id="f-workEmail" type="email" name="workEmail" required class="field" placeholder="m.papadopoulos@acme.com" autocomplete="email" inputmode="email" enterkeyhint="next" />
            </label>
            <label class="block" for="f-phone">
              <span class="eyebrow eyebrow-mute block mb-2">Direct phone</span>
              <input id="f-phone" type="tel" name="phone" class="field" placeholder="+30 ..." autocomplete="tel" inputmode="tel" enterkeyhint="next" />
            </label>
            <label class="block" for="f-companyName">
              <span class="eyebrow eyebrow-mute block mb-2">Company</span>
              <input id="f-companyName" type="text" name="companyName" required class="field" placeholder="Acme Industries" autocomplete="organization" enterkeyhint="next" />
            </label>
            <label class="block" for="f-role">
              <span class="eyebrow eyebrow-mute block mb-2">Role</span>
              <input id="f-role" type="text" name="role" class="field" placeholder="Head of Reward / People" autocomplete="organization-title" enterkeyhint="next" />
            </label>
            <label class="block" for="f-employees">
              <span class="eyebrow eyebrow-mute block mb-2">Employees in scope</span>
              <select id="f-employees" name="employees" class="field">
                <option value="">Select range</option>
                <option>Up to 250</option>
                <option>250 – 1,000</option>
                <option>1,000 – 3,000</option>
                <option>3,000 – 10,000</option>
                <option>10,000+</option>
              </select>
            </label>
            <label class="block" for="f-countries">
              <span class="eyebrow eyebrow-mute block mb-2">Countries in scope</span>
              <input id="f-countries" type="text" name="countries" class="field" placeholder="e.g. Greece, Germany, UAE" autocomplete="off" enterkeyhint="next" />
            </label>
          </div>

          <label class="block mt-6" for="f-message">
            <span class="eyebrow eyebrow-mute block mb-2">Anything we should know?</span>
            <textarea id="f-message" name="message" rows="3" class="field" placeholder="Current incumbent, renewal date, regional risks, integrations needed…" enterkeyhint="send"></textarea>
          </label>

          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
            <button type="submit" class="btn-primary">
              Book a consultation
              <span aria-hidden>→</span>
            </button>
            <p class="text-[12px] text-[var(--color-ink-mute)]">
              Submitting opens your mail client. We'll reply within 3 working days under NDA if requested.
            </p>
          </div>
        </form>
      </div>
    </section>

    <!-- ============================================================
         FOOTNOTES
         ============================================================ -->
    <section id="footnotes" class="py-16 section-brand-top stripe-gold bg-white">
      <div class="container-prose">
        <div class="eyebrow eyebrow-mute mb-6">Footnotes & sources</div>
        <ol class="grid md:grid-cols-3 gap-x-10 gap-y-8 list-none">
          {sources.map(s => (
            <li class="text-[13px] leading-relaxed text-[var(--color-ink-soft)]">
              <span class="font-mono mr-2" style="color: var(--color-brand-gold-dark);">[{s.n}]</span>
              {s.label}
              <a class="link-underline block mt-1" href={s.url} target="_blank" rel="noopener">{s.publisher} ↗</a>
            </li>
          ))}
        </ol>
      </div>
    </section>
  </main>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="section-brand-top stripe-tri py-14 bg-[var(--color-surface-soft)]" style="--stripe-h: 6px;">
    <div class="container-prose">
      <div class="grid md:grid-cols-12 gap-x-12 gap-y-10">
        <div class="md:col-span-5">
          <img src="/logo.png" alt="Global Team Plans" width="320" height="26" class="h-5 md:h-7 w-auto mb-4" />
          <p class="text-[14px] leading-relaxed max-w-md text-[var(--color-ink-soft)]">
            Certified TELUS&nbsp;Health partner agency. Global employee wellbeing plans for organisations that operate across borders.
          </p>
          <p class="mt-4 text-[12px] text-[var(--color-ink-mute)]">
            Headquartered in Athens, Greece. Serving brokers, consultancies, and enterprises globally.
          </p>
        </div>

        <div class="md:col-span-2">
          <div class="eyebrow eyebrow-mute mb-3">Programme</div>
          <ul class="space-y-2 text-[14px]">
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#audience">Who we help</a></li>
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#partnership">Partnership</a></li>
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#programme">What's included</a></li>
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#evidence">Evidence</a></li>
          </ul>
        </div>

        <div class="md:col-span-2">
          <div class="eyebrow eyebrow-mute mb-3">Procurement</div>
          <ul class="space-y-2 text-[14px]">
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#governance">Governance</a></li>
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#pricing">Pricing</a></li>
            <li><a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#contact">Book a consultation</a></li>
          </ul>
        </div>

        <div class="md:col-span-3">
          <div class="eyebrow eyebrow-mute mb-3">Contact</div>
          <ul class="space-y-2 text-[14px] text-[var(--color-ink-soft)]">
            <li><a class="link-underline" href="mailto:find@gtpinsurance.gr">find@gtpinsurance.gr</a></li>
            <li>Athens, Greece</li>
          </ul>
        </div>
      </div>

      <!-- Tri-colour brand rail -->
      <div class="mt-10 mb-6 flex items-center gap-3">
        <span class="tri-rule"><span class="b1"></span><span class="b2"></span><span class="b3"></span></span>
        <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-mute)]">Global · Team · Plans</span>
      </div>

      <hr class="rule mb-6" />

      <div class="flex flex-col md:flex-row md:justify-between gap-3 text-[12px] text-[var(--color-ink-mute)]">
        <div>&copy; {new Date().getFullYear()} Global Team Plans. All rights reserved. TELUS&nbsp;Health is a registered trademark of TELUS Corporation, used here in the context of a partner-agency relationship.</div>
        <div class="flex gap-6">
          <a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#">Privacy</a>
          <a class="hover:text-[var(--color-brand-blue)] transition-colors" href="#">Terms</a>
          <a class="hover:text-[var(--color-brand-blue)] transition-colors" href="mailto:find@gtpinsurance.gr">Contact</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Plan select + form submit -->
  <script is:inline>
    var selectedPlan = '';
    document.querySelectorAll('.plan-select-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        selectedPlan = this.getAttribute('data-plan');
        var sp = document.getElementById('selectedPlan');
        if (sp) sp.textContent = 'Discussing ' + selectedPlan;
        var c = document.getElementById('contact');
        if (c) c.scrollIntoView({ behavior: 'smooth' });
      });
    });

    var form = document.getElementById('demoForm');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var fd = new FormData(e.target);
        var d = {};
        fd.forEach(function (v, k) { d[k] = v; });

        var subject = 'TELUS Health EAP — Consultation request — ' + (d.companyName || 'New enquiry');
        var lines = [
          'Hello GTP,',
          '',
          'I would like to book a consultation about the TELUS Health Employee Assistance Programme.',
          '',
          'Contact',
          '  Name      : ' + (d.firstName || '') + ' ' + (d.lastName || ''),
          '  Email     : ' + (d.workEmail || ''),
          '  Phone     : ' + (d.phone || ''),
          '  Role      : ' + (d.role || ''),
          '',
          'Company',
          '  Name      : ' + (d.companyName || ''),
          '  Employees : ' + (d.employees || ''),
          '  Countries : ' + (d.countries || ''),
          '',
          (selectedPlan ? 'Indicative tier: ' + selectedPlan : ''),
          '',
          (d.message ? 'Notes: ' + d.message : ''),
          '',
          'Best regards,',
          (d.firstName || '') + ' ' + (d.lastName || '')
        ];
        var body = lines.filter(function (l) { return l !== null; }).join('\n');
        window.location.href = 'mailto:find@gtpinsurance.gr?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
        e.target.reset();
        var sp = document.getElementById('selectedPlan');
        if (sp) sp.textContent = '';
        selectedPlan = '';
      });
    }
  </script>
</BaseLayout>
