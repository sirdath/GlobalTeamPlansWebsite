---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { services } from '../data/services';
import { pricing, pricingNote } from '../data/pricing';
import { benefits, accreditations } from '../data/stats';

const pageTitle = "Global Team Plans | Professional Employee Assistance Programme (EAP)";
const pageDescription = "Support 35+ Million lives with our professional EAP services across 180 countries. 24/7 crisis support, mental health resources, and digital wellbeing.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Nav />

  <main>
    <!-- Hero Section -->
    <Hero />

    <!-- Services Section -->
    <section id="services" class="py-24 px-4 bg-brand-bg-secondary/30 relative">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Comprehensive <span class="text-teal">Wellbeing Solutions</span></h2>
          <p class="max-w-2xl mx-auto text-slate-400 text-sm md:text-base leading-relaxed">
            24/7/365 support across mental health, social, physical and financial pillars with world-class clinical governance.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {services.map(service => (
            <ServiceCard
              title={service.title}
              description={service.description}
              features={service.features}
              type={service.type as any}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Results Section -->
    <section id="results" class="py-24 px-4 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-teal/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>

      <div class="max-w-6xl mx-auto relative z-10">
        <div class="text-center mb-16 reveal">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Proven <span class="text-teal">Results & Measurable Impact</span></h2>
          <p class="text-slate-400 text-sm">Evidence-based wellbeing solutions that deliver tangible business outcomes and ROI.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
          {[
            { value: '50%', label: 'Reduction in poor mental health ratings' },
            { value: '38%', label: 'Drop in presenteeism hours' },
            { value: '42%', label: 'Increase in good mental health ratings' }
          ].map(stat => (
            <div class="glass-card p-8 rounded-3xl reveal border-white/[0.03] group hover:border-teal/20">
              <div class="text-3xl sm:text-4xl md:text-5xl font-bold text-teal mb-4 stat-number" data-value={parseInt(stat.value)} data-suffix="%">{stat.value}</div>
              <div class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 mb-20">
          {benefits.map(benefit => (
            <div class="flex items-start text-left reveal group">
              <div class="w-10 h-10 bg-teal rounded-xl flex items-center justify-center mr-4 mt-1 flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  {benefit.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
                  {benefit.icon === 'bar-chart-3' && <><path d="M18 20V10M12 20V4M6 20v-6"/></>}
                  {benefit.icon === 'shield-check' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></>}
                  {benefit.icon === 'heart' && <><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></>}
                  {benefit.icon === 'alert-triangle' && <><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></>}
                  {benefit.icon === 'lock' && <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white mb-2">{benefit.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{benefit.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Accreditations / Trust -->
        <div class="text-center reveal">
          <h3 class="text-2xl font-bold text-teal mb-4">Trusted by Organizations Worldwide</h3>
          <p class="text-slate-400 mb-8 text-sm">
            Accredited by the Council on Accreditation with strict clinical governance standards.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            {accreditations.map(item => (
              <div class="glass-card p-6 rounded-2xl reveal border-white/[0.03]">
                <div class="w-10 h-10 bg-teal/20 rounded-xl flex items-center justify-center mb-4 mx-auto">
                  <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    {item.icon === 'badge-check' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></>}
                    {item.icon === 'building' && <><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></>}
                    {item.icon === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
                  </svg>
                </div>
                <h4 class="font-bold text-white mb-2">{item.title}</h4>
                <p class="text-slate-500 text-sm">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>



    <!-- Pricing Section -->
    <section id="pricing" class="py-24 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 reveal">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Flexible <span class="text-teal">Pricing Plans</span></h2>
          <p class="text-slate-400 text-sm max-w-2xl mx-auto">Choose the right level of support for your organization. All plans include our core EAP services with transparent, per-employee pricing.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto pt-6">
          {pricing.map(plan => (
            <div class={`glass-card p-6 sm:p-8 rounded-3xl border-white/[0.03] flex flex-col ${plan.popular ? 'border-teal/30 ring-1 ring-teal/20 md:scale-105 shadow-2xl shadow-teal/5 relative z-10' : ''}`}>
              {plan.popular && <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-teal text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest whitespace-nowrap">Most Popular</div>}
              <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
              <p class="text-slate-400 text-xs mb-6 uppercase tracking-widest">{plan.subtitle}</p>

              <div class="flex flex-wrap items-baseline gap-1 mb-1">
                <span class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">{plan.currency}{plan.priceYearly}</span>
                <span class="text-slate-500 text-xs sm:text-sm italic">per employee per year</span>
              </div>
              <p class="text-lg text-teal font-bold mb-10 tracking-tight">Monthly equivalent {plan.currency}{plan.priceMonthly}</p>

              <ul class="space-y-4 mb-10 flex-grow">
                {plan.features.map(feature => (
                  <li class="flex items-center text-sm text-slate-400">
                    <span class="text-teal mr-3 text-lg">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>

              <button data-plan={plan.name} class={`plan-select-btn w-full py-4 rounded-xl text-center font-bold transition-all cursor-pointer ${plan.popular ? 'bg-teal text-white hover:bg-teal-dark shadow-lg shadow-teal/10' : 'bg-white/5 text-white hover:bg-white/10 border border-white/10'}`}>
                {plan.cta}
              </button>
            </div>
          ))}
        </div>

        <div class="text-center mt-8">
          <p class="text-sm text-slate-500">{pricingNote}</p>
        </div>
      </div>
    </section>

    <!-- Lead Gen / Contact Section -->
    <section id="contact" class="py-24 px-4 relative overflow-hidden bg-brand-bg-secondary/30">
      <div class="max-w-3xl mx-auto">
        <div class="glass-card p-6 sm:p-8 md:p-12 rounded-2xl sm:rounded-[2.5rem] border-white/[0.05] relative z-10">
          <div class="text-center mb-10">
            <h2 class="text-2xl sm:text-3xl font-bold mb-4">Ready to Transform Your <span class="text-teal">Workplace Wellbeing</span>?</h2>
            <p class="text-slate-400 text-sm">Join over 35 million people who trust our global EAP services. Get started with a personalized demo.</p>
            <div id="selectedPlan" class="text-teal font-semibold mt-2"></div>
          </div>

          <form id="demoForm" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <input type="text" name="firstName" placeholder="First Name" class="bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-3.5 text-sm focus:border-teal/50 outline-none transition-all" required />
              <input type="text" name="lastName" placeholder="Last Name" class="bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-3.5 text-sm focus:border-teal/50 outline-none transition-all" required />
            </div>
            <input type="email" name="workEmail" placeholder="Work Email" class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-3.5 text-sm focus:border-teal/50 outline-none transition-all" required />
            <input type="text" name="companyName" placeholder="Company Name" class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-3.5 text-sm focus:border-teal/50 outline-none transition-all" required />
            <textarea name="message" placeholder="Tell us about your needs (optional)" rows="4" class="w-full bg-white/[0.03] border border-white/[0.08] rounded-xl px-5 py-3.5 text-sm focus:border-teal/50 outline-none transition-all resize-y"></textarea>

            <button type="submit" class="w-full bg-teal hover:bg-teal-dark text-white py-4 rounded-xl font-bold text-lg shadow-lg shadow-teal/10 transition-all hover:scale-[1.02]">
              Request Demo
            </button>
          </form>

          <div class="mt-8 pt-8 border-t border-white/[0.05] text-center">
             <p class="text-xs text-slate-500 mb-2">Prefer to speak directly?</p>
             <a href="mailto:find@gtpinsurance.gr" class="text-teal font-semibold hover:underline">Email us directly at find@gtpinsurance.gr</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 px-4 border-t border-white/[0.03] bg-brand-bg-secondary/50">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex flex-col items-center md:items-start gap-2">
        <span class="text-lg font-bold">Global Team Plans</span>
        <p class="text-slate-500 text-xs">Transforming workplace wellbeing across 180+ countries worldwide</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-8 text-xs text-slate-400">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="mailto:find@gtpinsurance.gr" class="hover:text-white transition-colors">Contact Us</a>
      </div>
      <div class="text-slate-600 text-[10px]">
        &copy; 2025 Global Team Plans. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- Plan Selection & Form Submission Scripts -->
  <script is:inline>
    let selectedPlan = '';

    // Plan selection from pricing buttons
    document.querySelectorAll('.plan-select-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        selectedPlan = this.getAttribute('data-plan');
        document.getElementById('selectedPlan').textContent = 'Selected: ' + selectedPlan + ' Plan';
        document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
      });
    });

    // Form submission via mailto
    document.getElementById('demoForm').addEventListener('submit', function(event) {
      event.preventDefault();

      var formData = new FormData(event.target);
      var data = {};
      formData.forEach(function(value, key) { data[key] = value; });

      var subject = 'EAP Demo Request - ' + data.companyName;
      var body = 'Hello,\n\nI would like to request a demo of your Employee Assistance Programme services.\n\nContact Details:\n- Name: ' + data.firstName + ' ' + data.lastName + '\n- Email: ' + data.workEmail + '\n- Company: ' + data.companyName + '\n' + (selectedPlan ? '- Selected Plan: ' + selectedPlan + ' Plan\n' : '') + '\n' + (data.message ? 'Message: ' + data.message + '\n' : '') + '\nPlease contact me to schedule a personalized demo.\n\nBest regards,\n' + data.firstName + ' ' + data.lastName;

      var mailtoUrl = 'mailto:find@gtpinsurance.gr?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      window.location.href = mailtoUrl;

      event.target.reset();
      document.getElementById('selectedPlan').textContent = '';
      selectedPlan = '';
    });
  </script>
</BaseLayout>
